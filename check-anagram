// Check Anagram for two Strings 
import java.util.*;

class Main {
    public static void main(String[] args) {
      
      System.out.println(checkAnagram("listen", "silent"));
    }
    
    public static boolean checkAnagram(String a, String b)
    {  int n=a.length();
        int m=b.length();
        if(m!=n)
        return false;
        
        char[] arrA=a.toCharArray();
       char[] arrB=b.toCharArray();
        
           Arrays.sort(arrA);
           Arrays.sort(arrB);
           
            for(int i=0; i<n; i++)
           {   if(arrA[i]!=arrB[i])
               return false;
               
           }
           return true;
    }     
    
}
